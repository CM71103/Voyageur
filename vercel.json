{
  "functions": {
    "server.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server.py"
    },
    {
      "source": "/",
      "destination": "/static/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/static/$1"
    }
  ]
}
